# =============================================================================
# OdinPad — copy to `.env` and fill in values. Only `VITE_*` vars are exposed to the client bundle.
# =============================================================================

# --- Required (Supabase) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Optional: Supabase project ref (e.g. for support / dashboard links; not required for runtime) ---
VITE_SUPABASE_PROJECT_ID=

# --- Optional: product analytics (POST JSON `{ event, ts, ...payload }`) ---
VITE_ANALYTICS_INGEST_URL=

# --- Feature flags (client; boolean: omit, `true`, `1`, or `false`, `0`) ---
# Onboarding v2 flow — when false, onboarding routes behave as today without the v2 gate.
VITE_FF_ONBOARDING_V2=
# Settings “command center” page — when false, `/settings` redirects home.
VITE_FF_SETTINGS_COMMAND_CENTER=
# Guided tour in the novel workspace.
VITE_FF_GUIDED_TOUR=
# Groq / AI editorial, Idea Web AI, Sandbox AI. Can also be overridden via Supabase `app_remote_config`.
VITE_FF_AI_EDITORIAL=
# Multi-step book creation + series metadata. Remote key `richer_book_creation` in `app_remote_config`.
VITE_FF_RICHER_BOOK_CREATION=

# --- Optional: auth redirect base when not using `window.location.origin` (OAuth / email magic links) ---
# VITE_AUTH_REDIRECT_URL=

# --- Injected at build time (see vite.config.ts); do not set manually unless overriding ---
# VITE_APP_VERSION=

# --- Edge Function secrets (set via `supabase secrets set KEY=value`, NOT in .env) ---
# Groq API key for AI editorial and daily quote features.
# GROQ_API_KEY=
# Optional: override default Groq model (default: llama-3.3-70b-versatile).
# GROQ_MODEL=
# Deployed frontend URL; used by Edge Functions for CORS `Access-Control-Allow-Origin`.
# Example: https://odinpad.vercel.app
# FRONTEND_URL=

# --- Local Supabase CLI only (never commit real secrets) — used by `npm run supabase:push` etc. ---
# SUPABASE_DB_PASSWORD=
